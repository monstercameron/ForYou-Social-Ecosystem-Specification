{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foryousocial.network/schemas/launch.schema.json",
  "title": "ForYou Launch Baseline JSON Schemas",
  "description": "Machine-readable JSON Schema definitions for the ForYou launch baseline. This file is a schema library: most consumers should $ref a specific $defs entry. The root schema validates a full transport message.",
  "$ref": "#/$defs/TransportMessage",
  "$defs": {
    "DidKey": {
      "type": "string",
      "pattern": "^did:key:[A-Za-z0-9]+$",
      "minLength": 10
    },
    "MessageId": {
      "type": "string",
      "minLength": 1
    },
    "ContentAddress": {
      "type": "string",
      "pattern": "^ipfs://[a-z2-7]+$",
      "minLength": 12
    },
    "TopicKey": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1
    },
    "Version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor"],
      "properties": {
        "major": { "type": "integer", "minimum": 1 },
        "minor": { "type": "integer", "minimum": 0 }
      }
    },
    "Payment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chain", "funding_reference", "amount"],
      "properties": {
        "chain": { "type": "string", "enum": ["bitcoin", "ethereum"] },
        "funding_reference": { "type": "string", "minLength": 1 },
        "amount": { "type": "string", "minLength": 1 },
        "block_reference": { "type": "string" },
        "payment_class": { "type": "string" },
        "acceptance_state": {
          "type": "string",
          "enum": ["provisional", "verified", "rejected"]
        },
        "verifier_id": { "$ref": "#/$defs/DidKey" }
      }
    },
    "SubmissionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "plan_id",
        "receipt_id",
        "message_id",
        "units_charged",
        "provider_signature"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/DidKey" },
        "plan_id": { "type": "string", "minLength": 1 },
        "receipt_id": { "type": "string", "minLength": 1 },
        "message_id": { "$ref": "#/$defs/MessageId" },
        "units_charged": { "type": "number", "exclusiveMinimum": 0 },
        "provider_signature": { "type": "string", "minLength": 1 },
        "period_start": { "type": "string", "format": "date-time" },
        "period_end": { "type": "string", "format": "date-time" },
        "tier": { "type": "string" },
        "remaining_units_hint": { "type": "number", "minimum": 0 },
        "audit_log_root": { "type": "string" },
        "audit_proof_ref": { "type": "string" }
      }
    },
    "SubmissionToken": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "plan_id",
        "token_id",
        "author_id",
        "tier_scope",
        "units_limit",
        "valid_from",
        "valid_until",
        "provider_signature"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/DidKey" },
        "plan_id": { "type": "string", "minLength": 1 },
        "token_id": { "type": "string", "minLength": 1 },
        "author_id": { "$ref": "#/$defs/DidKey" },
        "tier_scope": {
          "type": "string",
          "enum": [
            "recommend",
            "follow_source",
            "follow_topic",
            "subscribe_thread",
            "alias_registration"
          ]
        },
        "units_limit": { "type": "number", "exclusiveMinimum": 0 },
        "valid_from": { "type": "string", "format": "date-time" },
        "valid_until": { "type": "string", "format": "date-time" },
        "provider_signature": { "type": "string", "minLength": 1 },
        "remaining_units_hint": { "type": "number", "minimum": 0 },
        "redeemer_scope": { "type": "string" },
        "device_group_id": { "type": "string", "minLength": 1 },
        "audit_log_root": { "type": "string" },
        "audit_proof_ref": { "type": "string" }
      }
    },
    "ProviderPlanSchedule": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "provider_id",
        "plan_id",
        "chain",
        "minimum_funding_amount",
        "recipient_reference"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/DidKey" },
        "plan_id": { "type": "string", "minLength": 1 },
        "chain": { "type": "string", "enum": ["bitcoin", "ethereum"] },
        "duration_seconds": { "type": "integer", "minimum": 1 },
        "renewal_model": { "type": "string" },
        "included_units": { "type": "number", "minimum": 0 },
        "unit_costs": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "minimum_funding_amount": { "type": "string", "minLength": 1 },
        "recipient_reference": { "type": "string", "minLength": 1 },
        "schedule_version": { "type": "string", "minLength": 1 },
        "effective_time": { "type": "string", "format": "date-time" },
        "custody_model": {
          "type": "string",
          "enum": ["self-custody", "assisted-self-custody", "custodial"]
        },
        "revenue_split": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "provider_share": { "type": "number", "minimum": 0, "maximum": 1 },
            "network_service_share": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "reserve_share": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "auditability": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "transparency_log_ref": { "type": "string" },
            "accounting_report_ref": { "type": "string" }
          }
        },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "ProviderAccountingReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "provider_id",
        "plan_id",
        "window",
        "funding_total",
        "units_issued",
        "units_remaining",
        "audit_log_root",
        "audit_log_size",
        "signature"
      ],
      "properties": {
        "provider_id": { "$ref": "#/$defs/DidKey" },
        "plan_id": { "type": "string", "minLength": 1 },
        "window": { "type": "string", "minLength": 1 },
        "funding_total": { "type": "string", "minLength": 1 },
        "units_issued": { "type": "integer", "minimum": 0 },
        "units_remaining": { "type": "integer", "minimum": 0 },
        "audit_log_root": { "type": "string", "minLength": 1 },
        "audit_log_size": { "type": "integer", "minimum": 0 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "VerificationResult": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "chain",
        "funding_reference",
        "observed_amount",
        "observed_at",
        "acceptance_state",
        "verifier_id"
      ],
      "properties": {
        "chain": { "type": "string", "enum": ["bitcoin", "ethereum"] },
        "funding_reference": { "type": "string", "minLength": 1 },
        "observed_amount": { "type": "string", "minLength": 1 },
        "observed_at": { "type": "string", "format": "date-time" },
        "acceptance_state": {
          "type": "string",
          "enum": ["provisional", "verified", "rejected"]
        },
        "verifier_id": { "$ref": "#/$defs/DidKey" },
        "block_reference": { "type": "string" },
        "recipient_reference": { "type": "string" },
        "payment_class": { "type": "string" },
        "reason_code": { "type": "string" }
      }
    },
    "WorkClaimEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["log_root", "log_ref"],
      "properties": {
        "log_root": { "type": "string", "minLength": 1 },
        "log_ref": {
          "anyOf": [
            { "$ref": "#/$defs/ContentAddress" },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "WorkClaimReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "window",
        "bucket_id",
        "operator_id",
        "work_units",
        "unit_kind",
        "evidence",
        "signature"
      ],
      "properties": {
        "window": { "type": "string", "minLength": 1 },
        "bucket_id": { "type": "string", "minLength": 1 },
        "operator_id": { "$ref": "#/$defs/DidKey" },
        "work_units": { "type": "integer", "minimum": 0 },
        "unit_kind": { "type": "string", "minLength": 1 },
        "evidence": { "$ref": "#/$defs/WorkClaimEvidence" },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "PayoutEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["bucket_id", "operator_id", "amount"],
      "properties": {
        "bucket_id": { "type": "string", "minLength": 1 },
        "operator_id": { "$ref": "#/$defs/DidKey" },
        "amount": { "type": "string", "minLength": 1 }
      }
    },
    "PayoutSettlementReport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "window",
        "payer_id",
        "chain",
        "payout_reference",
        "total_paid",
        "payouts",
        "signature"
      ],
      "properties": {
        "window": { "type": "string", "minLength": 1 },
        "payer_id": { "$ref": "#/$defs/DidKey" },
        "chain": { "type": "string", "enum": ["bitcoin", "ethereum"] },
        "payout_reference": { "type": "string", "minLength": 1 },
        "total_paid": { "type": "string", "minLength": 1 },
        "payouts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/PayoutEntry" }
        },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "Delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author_id",
        "signer_id",
        "delegation_id",
        "valid_from",
        "valid_until",
        "delegation_signature"
      ],
      "properties": {
        "author_id": { "$ref": "#/$defs/DidKey" },
        "signer_id": { "$ref": "#/$defs/DidKey" },
        "delegation_id": { "type": "string", "minLength": 1 },
        "valid_from": { "type": "string", "format": "date-time" },
        "valid_until": { "type": "string", "format": "date-time" },
        "delegation_signature": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "HostHint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_id", "endpoint", "last_seen"],
      "properties": {
        "host_id": { "$ref": "#/$defs/DidKey" },
        "endpoint": { "type": "string", "format": "uri", "pattern": "^https://.*" },
        "last_seen": { "type": "string", "format": "date-time" },
        "jurisdiction": { "type": "string" },
        "policy_hint": { "type": "string" },
        "transport_capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "type": "number", "minimum": 0 }
      }
    },
    "EncryptedStateRecipient": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kid",
        "recipient_pubkey",
        "epk",
        "wrap_nonce",
        "wrapped_key"
      ],
      "properties": {
        "kid": { "type": "string", "minLength": 1 },
        "recipient_pubkey": { "type": "string", "minLength": 1 },
        "epk": { "type": "string", "minLength": 1 },
        "wrap_nonce": { "type": "string", "minLength": 1 },
        "wrapped_key": { "type": "string", "minLength": 1 }
      }
    },
    "EncryptedStateEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "nonce", "ciphertext", "recipients"],
      "properties": {
        "v": { "type": "integer", "minimum": 1 },
        "nonce": { "type": "string", "minLength": 1 },
        "ciphertext": { "type": "string", "minLength": 1 },
        "recipients": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/EncryptedStateRecipient" }
        }
      }
    },
    "CurationStateV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["v"],
      "properties": {
        "v": { "const": 1 },
        "muted_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/DidKey" }
        },
        "blocked_sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/DidKey" }
        },
        "hidden_message_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/MessageId" }
        },
        "bookmarked_message_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/MessageId" }
        },
        "trust_source_weights": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/DidKey" },
          "additionalProperties": { "type": "number" }
        },
        "boost_source_weights": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/DidKey" },
          "additionalProperties": { "type": "number" }
        },
        "downrank_source_weights": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/DidKey" },
          "additionalProperties": { "type": "number" }
        },
        "private_tags": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/MessageId" },
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "private_notes": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/MessageId" },
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "SourceListItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["list_id", "title", "author_ids"],
      "properties": {
        "list_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "author_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/DidKey" }
        }
      }
    },
    "SourceListsStateV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["v", "lists"],
      "properties": {
        "v": { "const": 1 },
        "lists": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceListItem" }
        }
      }
    },
    "CollectionItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["collection_id", "title", "message_ids"],
      "properties": {
        "collection_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "message_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/MessageId" }
        }
      }
    },
    "CollectionsStateV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["v", "collections"],
      "properties": {
        "v": { "const": 1 },
        "collections": {
          "type": "array",
          "items": { "$ref": "#/$defs/CollectionItem" }
        }
      }
    },
    "ReadingQueueItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["message_id"],
      "properties": {
        "message_id": { "$ref": "#/$defs/MessageId" }
      }
    },
    "ReadingQueueStateV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["v", "queue"],
      "properties": {
        "v": { "const": 1 },
        "queue": {
          "type": "array",
          "items": { "$ref": "#/$defs/ReadingQueueItem" }
        }
      }
    },
    "ProfilePinsStateV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["v", "pinned_message_ids"],
      "properties": {
        "v": { "const": 1 },
        "pinned_message_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/MessageId" }
        }
      }
    },
    "PrivateStatePlaintext": {
      "oneOf": [
        { "$ref": "#/$defs/CurationStateV1" },
        { "$ref": "#/$defs/SourceListsStateV1" },
        { "$ref": "#/$defs/CollectionsStateV1" },
        { "$ref": "#/$defs/ReadingQueueStateV1" },
        { "$ref": "#/$defs/ProfilePinsStateV1" }
      ]
    },
    "PostPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["content_format", "content_summary"],
      "properties": {
        "content_format": { "type": "string", "minLength": 1 },
        "content_summary": { "type": "string", "minLength": 1 },
        "links": { "type": "array", "items": { "type": "string" } },
        "attachments": { "type": "array", "items": {} },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "ReplyPayload": {
      "allOf": [
        { "$ref": "#/$defs/PostPayload" },
        {
          "type": "object",
          "required": ["reply_to"],
          "properties": {
            "reply_to": { "$ref": "#/$defs/MessageId" }
          }
        }
      ]
    },
    "QuotePayload": {
      "allOf": [
        { "$ref": "#/$defs/PostPayload" },
        {
          "type": "object",
          "required": ["target_message_id"],
          "properties": {
            "target_message_id": { "$ref": "#/$defs/MessageId" }
          }
        }
      ]
    },
    "CounterpointPayload": {
      "allOf": [
        { "$ref": "#/$defs/PostPayload" },
        {
          "type": "object",
          "required": ["target_message_id"],
          "properties": {
            "target_message_id": { "$ref": "#/$defs/MessageId" }
          }
        }
      ]
    },
    "RecommendPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target_message_id"],
      "properties": {
        "target_message_id": { "$ref": "#/$defs/MessageId" },
        "context": { "type": "string" }
      }
    },
    "FollowSourcePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target_author_id"],
      "properties": {
        "target_author_id": { "$ref": "#/$defs/DidKey" }
      }
    },
    "FollowTopicPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target_topic"],
      "properties": {
        "target_topic": { "$ref": "#/$defs/TopicKey" }
      }
    },
    "SubscribeThreadPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target_thread_id"],
      "properties": {
        "target_thread_id": { "$ref": "#/$defs/MessageId" }
      }
    },
    "WithdrawPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target_message_id"],
      "properties": {
        "target_message_id": { "$ref": "#/$defs/MessageId" },
        "reason_code": { "type": "string" },
        "replacement_reference": { "type": "string" }
      }
    },
    "PrivateStateUpdatePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "state_kind",
        "encrypted_state",
        "encryption_scheme",
        "encryption_scope",
        "device_group_id",
        "state_sequence"
      ],
      "properties": {
        "state_kind": { "type": "string", "minLength": 1 },
        "encrypted_state": { "$ref": "#/$defs/EncryptedStateEnvelope" },
        "encryption_scheme": {
          "type": "string",
          "enum": ["x25519-xchacha20poly1305"]
        },
        "encryption_scope": { "type": "string", "enum": ["device_group"] },
        "device_group_id": { "type": "string", "minLength": 1 },
        "state_sequence": { "type": "integer", "minimum": 0 },
        "supersedes": { "type": "array", "items": { "type": "string" } },
        "state_summary": { "type": "string" },
        "compaction_kind": { "type": "string" }
      }
    },
    "AliasRegistrationPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["alias"],
      "properties": {
        "alias": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string" },
        "display_name": { "type": "string" },
        "bio": { "type": "string" },
        "avatar_reference": { "type": "string" },
        "profile_links": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "PollPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["prompt", "options"],
      "properties": {
        "prompt": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "duration_seconds": { "type": "integer", "minimum": 1 },
        "closing_time": { "type": "string", "format": "date-time" }
      }
    },
    "AdvertisementPayload": {
      "allOf": [
        { "$ref": "#/$defs/PostPayload" },
        {
          "type": "object",
          "required": ["sponsor_reference"],
          "properties": {
            "sponsor_reference": { "type": "string", "minLength": 1 },
            "campaign": { "type": "string" },
            "targeting_scope": { "type": "object", "additionalProperties": true },
            "payout_rules": { "type": "object", "additionalProperties": true }
          }
        }
      ]
    },
    "MessageBase": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "message_id",
        "author_id",
        "timestamp",
        "message_type",
        "version",
        "signature",
        "payload"
      ],
      "properties": {
        "message_id": { "$ref": "#/$defs/MessageId" },
        "author_id": { "$ref": "#/$defs/DidKey" },
        "signer_id": { "$ref": "#/$defs/DidKey" },
        "delegation": { "$ref": "#/$defs/Delegation" },
        "timestamp": { "type": "string", "format": "date-time" },
        "message_type": { "type": "string" },
        "version": { "$ref": "#/$defs/Version" },
        "content_address": { "$ref": "#/$defs/ContentAddress" },
        "thread_id": { "$ref": "#/$defs/MessageId" },
        "language": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "topic_tags": { "type": "array", "items": { "$ref": "#/$defs/TopicKey" } },
        "media_kinds": { "type": "array", "items": { "type": "string" } },
        "is_ad": { "type": "boolean" },
        "content_warning_flags": { "type": "array", "items": { "type": "string" } },
        "submission_receipt": { "$ref": "#/$defs/SubmissionReceipt" },
        "submission_token": { "$ref": "#/$defs/SubmissionToken" },
        "payment": { "$ref": "#/$defs/Payment" },
        "signature": { "type": "string", "minLength": 1 },
        "payload": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "required": ["signer_id"] },
          "then": { "required": ["delegation"] }
        }
      ]
    },
    "PostMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "required": ["submission_receipt"],
          "properties": {
            "message_type": { "const": "post" },
            "is_ad": { "const": false },
            "payload": { "$ref": "#/$defs/PostPayload" }
          }
        }
      ]
    },
    "ReplyMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "required": ["submission_receipt", "thread_id"],
          "properties": {
            "message_type": { "const": "reply" },
            "payload": { "$ref": "#/$defs/ReplyPayload" }
          }
        }
      ]
    },
    "QuoteMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "required": ["submission_receipt"],
          "properties": {
            "message_type": { "const": "quote" },
            "payload": { "$ref": "#/$defs/QuotePayload" }
          }
        }
      ]
    },
    "CounterpointMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "required": ["submission_receipt"],
          "properties": {
            "message_type": { "const": "counterpoint" },
            "payload": { "$ref": "#/$defs/CounterpointPayload" }
          }
        }
      ]
    },
    "RecommendMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "recommend" },
            "payload": { "$ref": "#/$defs/RecommendPayload" }
          },
          "anyOf": [
            { "required": ["submission_receipt"] },
            { "required": ["submission_token"] }
          ]
        }
      ]
    },
    "FollowSourceMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "follow_source" },
            "payload": { "$ref": "#/$defs/FollowSourcePayload" }
          },
          "anyOf": [
            { "required": ["submission_receipt"] },
            { "required": ["submission_token"] }
          ]
        }
      ]
    },
    "FollowTopicMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "follow_topic" },
            "payload": { "$ref": "#/$defs/FollowTopicPayload" }
          },
          "anyOf": [
            { "required": ["submission_receipt"] },
            { "required": ["submission_token"] }
          ]
        }
      ]
    },
    "SubscribeThreadMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "subscribe_thread" },
            "payload": { "$ref": "#/$defs/SubscribeThreadPayload" }
          },
          "anyOf": [
            { "required": ["submission_receipt"] },
            { "required": ["submission_token"] }
          ]
        }
      ]
    },
    "WithdrawMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "required": ["submission_receipt"],
          "properties": {
            "message_type": { "const": "withdraw" },
            "payload": { "$ref": "#/$defs/WithdrawPayload" }
          }
        }
      ]
    },
    "PrivateStateUpdateMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "private_state_update" },
            "payload": { "$ref": "#/$defs/PrivateStateUpdatePayload" }
          }
        }
      ]
    },
    "AliasRegistrationMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "alias_registration" },
            "payload": { "$ref": "#/$defs/AliasRegistrationPayload" }
          },
          "anyOf": [
            { "required": ["submission_receipt"] },
            { "required": ["submission_token"] }
          ]
        }
      ]
    },
    "PollMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "properties": {
            "message_type": { "const": "poll" },
            "payload": { "$ref": "#/$defs/PollPayload" }
          }
        }
      ]
    },
    "AdvertisementMessage": {
      "allOf": [
        { "$ref": "#/$defs/MessageBase" },
        {
          "type": "object",
          "required": ["is_ad"],
          "properties": {
            "message_type": { "const": "advertisement" },
            "is_ad": { "const": true },
            "payload": { "$ref": "#/$defs/AdvertisementPayload" }
          },
          "anyOf": [
            { "required": ["payment"] },
            { "required": ["submission_receipt"] }
          ]
        }
      ]
    },
    "CandidateItem": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "message_id",
        "author_id",
        "timestamp",
        "content_type",
        "content_address",
        "is_ad"
      ],
      "properties": {
        "message_id": { "$ref": "#/$defs/MessageId" },
        "author_id": { "$ref": "#/$defs/DidKey" },
        "timestamp": { "type": "string", "format": "date-time" },
        "content_type": { "type": "string" },
        "content_address": { "$ref": "#/$defs/ContentAddress" },
        "thread_id": { "$ref": "#/$defs/MessageId" },
        "reply_to": { "$ref": "#/$defs/MessageId" },
        "target_message_id": { "$ref": "#/$defs/MessageId" },
        "target_author_id": { "$ref": "#/$defs/DidKey" },
        "target_topic": { "$ref": "#/$defs/TopicKey" },
        "language": { "type": "string" },
        "is_ad": { "type": "boolean" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "topic_tags": { "type": "array", "items": { "$ref": "#/$defs/TopicKey" } },
        "media_kinds": { "type": "array", "items": { "type": "string" } },
        "payment_class": { "type": "string" },
        "content_size": { "type": "integer", "minimum": 0 },
        "signature_status": { "type": "string" },
        "message_status": {
          "type": "string",
          "enum": ["active", "withdrawn", "unavailable", "blocked"]
        },
        "target_status": {
          "type": ["string", "null"],
          "enum": ["active", "withdrawn", "unavailable", "blocked", null]
        },
        "reply_count": { "type": "integer", "minimum": 0 },
        "quote_count": { "type": "integer", "minimum": 0 },
        "counterpoint_count": { "type": "integer", "minimum": 0 },
        "recommend_count": { "type": "integer", "minimum": 0 },
        "weighted_recommend_score": { "type": "number" },
        "thread_subscriber_count": { "type": "integer", "minimum": 0 },
        "topic_follower_count": { "type": "integer", "minimum": 0 },
        "link_domains": { "type": "array", "items": { "type": "string" } },
        "geo_scope": { "type": "string" },
        "content_warning_flags": { "type": "array", "items": { "type": "string" } },
        "reshare_of": { "$ref": "#/$defs/MessageId" },
        "edit_of": { "$ref": "#/$defs/MessageId" },
        "retention_policy": { "type": "string" }
      }
    },
    "CandidateChunkResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["chunk_id", "generated_at", "items"],
      "properties": {
        "chunk_id": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/CandidateItem" }
        },
        "next_cursor": { "type": "string" }
      }
    },
    "ContentLocationHints": {
      "type": "object",
      "additionalProperties": true,
      "required": ["content_address", "host_hints"],
      "properties": {
        "content_address": { "$ref": "#/$defs/ContentAddress" },
        "host_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/HostHint" }
        }
      }
    },
    "HostRecord": {
      "type": "object",
      "additionalProperties": true,
      "required": ["host_id", "endpoint"],
      "properties": {
        "host_id": { "$ref": "#/$defs/DidKey" },
        "endpoint": { "type": "string", "format": "uri", "pattern": "^https://.*" },
        "last_seen": { "type": "string", "format": "date-time" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "jurisdiction": { "type": "string" },
        "policy_hint": { "type": "string" },
        "peers": { "type": "array", "items": { "$ref": "#/$defs/HostHint" } },
        "measured_at": { "type": "string", "format": "date-time" }
      }
    },
    "ContentRetrievalSuccess": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "content_address",
        "message_id",
        "content_format",
        "content",
        "retrieved_at"
      ],
      "properties": {
        "content_address": { "$ref": "#/$defs/ContentAddress" },
        "message_id": { "$ref": "#/$defs/MessageId" },
        "content_format": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" }
      }
    },
    "ContentRetrievalUnavailable": {
      "type": "object",
      "additionalProperties": true,
      "required": ["content_address", "status", "reason"],
      "properties": {
        "content_address": { "$ref": "#/$defs/ContentAddress" },
        "status": { "const": "unavailable" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "ContentRetrievalResponse": {
      "oneOf": [
        { "$ref": "#/$defs/ContentRetrievalSuccess" },
        { "$ref": "#/$defs/ContentRetrievalUnavailable" }
      ]
    },
    "RankingProfile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "version",
        "profile_id",
        "display_name",
        "objectives",
        "topic_preferences",
        "language_preferences",
        "sensitivity_filters"
      ],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "profile_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "topic_preferences": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "language_preferences": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sensitivity_filters": { "type": "object", "additionalProperties": true }
      }
    },
    "CandidateContent": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "candidate_id",
        "author_id",
        "timestamp",
        "content_type",
        "content_address",
        "is_ad"
      ],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "author_id": { "$ref": "#/$defs/DidKey" },
        "timestamp": { "type": "string", "format": "date-time" },
        "language": { "type": "string" },
        "content_type": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "thread_id": { "$ref": "#/$defs/MessageId" },
        "reply_to": { "type": ["string", "null"] },
        "content_address": { "$ref": "#/$defs/ContentAddress" },
        "payment_class": { "type": "string" },
        "is_ad": { "type": "boolean" },
        "local_features": { "type": "object", "additionalProperties": true },
        "engagement_features": { "type": "object", "additionalProperties": true },
        "retrieval_hints": { "type": "object", "additionalProperties": true }
      }
    },
    "RankingEngineInput": {
      "type": "object",
      "additionalProperties": true,
      "required": ["profile", "candidates", "runtime"],
      "properties": {
        "profile": { "$ref": "#/$defs/RankingProfile" },
        "candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/CandidateContent" }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": true,
          "required": ["mode", "model_id"],
          "properties": {
            "mode": { "type": "string", "enum": ["local", "remote", "hybrid"] },
            "model_id": { "type": "string", "minLength": 1 },
            "max_items": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "RankingEngineOutput": {
      "type": "object",
      "additionalProperties": true,
      "required": ["model_id", "mode", "results"],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["local", "remote", "hybrid"] },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["candidate_id", "score"],
            "properties": {
              "candidate_id": { "type": "string", "minLength": 1 },
              "score": { "type": "number" }
            }
          }
        }
      }
    },
    "TransportMessage": {
      "oneOf": [
        { "$ref": "#/$defs/PostMessage" },
        { "$ref": "#/$defs/ReplyMessage" },
        { "$ref": "#/$defs/QuoteMessage" },
        { "$ref": "#/$defs/CounterpointMessage" },
        { "$ref": "#/$defs/RecommendMessage" },
        { "$ref": "#/$defs/FollowSourceMessage" },
        { "$ref": "#/$defs/FollowTopicMessage" },
        { "$ref": "#/$defs/SubscribeThreadMessage" },
        { "$ref": "#/$defs/WithdrawMessage" },
        { "$ref": "#/$defs/PrivateStateUpdateMessage" },
        { "$ref": "#/$defs/AliasRegistrationMessage" },
        { "$ref": "#/$defs/PollMessage" },
        { "$ref": "#/$defs/AdvertisementMessage" }
      ]
    }
  }
}
